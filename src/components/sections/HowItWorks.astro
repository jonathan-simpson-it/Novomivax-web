---
import { HOW_IT_WORKS } from '../../data/siteConfig';

const stages = HOW_IT_WORKS.stages;
---

<section id="how-it-works" class="section">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2>{HOW_IT_WORKS.heading}</h2>
      <p class="section-intro">{HOW_IT_WORKS.intro}</p>
    </div>

    <div class="stage-panel stage-panel--alt reveal-on-scroll">
      <div class="stage-content">
        <span class="stage-number">01</span>
        <h3>{stages[0].heading}</h3>
        <p>{stages[0].body}</p>
        <ul class="stage-list">
          {stages[0].problems.map((problem) => (
            <li>{problem}</li>
          ))}
        </ul>
        <p class="stage-note">{stages[0].note}</p>
      </div>
      <div class="stage-visual">
        <div class="diagram-problem">
          <div class="diagram-split">
            <div class="diagram-side diagram-side--blocked">
              <div class="diagram-side-label">Current State</div>
              <div class="tumour tumour--cold">
                <div class="tumour-inner"></div>
              </div>
              <div class="diagram-status">Blocked</div>
              <div class="barrier-labels">
                <div class="barrier-item">
                  <span class="barrier-dot"></span>
                  <span class="barrier-text">Heterogeneity</span>
                </div>
                <div class="barrier-item">
                  <span class="barrier-dot"></span>
                  <span class="barrier-text">No Target</span>
                </div>
                <div class="barrier-item">
                  <span class="barrier-dot"></span>
                  <span class="barrier-text">Suppressive TME</span>
                </div>
              </div>
            </div>
            <div class="diagram-vs">vs</div>
            <div class="diagram-side diagram-side--target">
              <div class="diagram-side-label">What's Needed</div>
              <div class="tumour tumour--hot">
                <div class="tumour-inner"></div>
                <div class="target-ring"></div>
                <div class="target-dot"></div>
              </div>
              <div class="diagram-status diagram-status--active">Druggable Target</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="stage-panel reveal-on-scroll">
      <div class="stage-visual">
        <div class="diagram-solution">
          <div class="solution-center">
            <span class="solution-center-text">NOVOMI VAX</span>
          </div>
          <div class="solution-card solution-card--1">
            <div class="solution-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            </div>
            <strong>Druggable Target</strong>
            <span>Labels tumours for immune recognition</span>
          </div>
          <div class="solution-card solution-card--2">
            <div class="solution-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/>
                <path d="M8 14a4 4 0 0 0-4 4v2h16v-2a4 4 0 0 0-4-4"/>
              </svg>
            </div>
            <strong>Overcomes Heterogeneity</strong>
            <span>Works across varying tumour cells</span>
          </div>
          <div class="solution-card solution-card--3">
            <div class="solution-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <strong>Reprograms TME</strong>
            <span>Makes microenvironment immune-permissive</span>
          </div>
        </div>
      </div>
      <div class="stage-content">
        <span class="stage-number">02</span>
        <h3>{stages[1].heading}</h3>
        <p>{stages[1].body}</p>
        <ul class="stage-list">
          {stages[1].points.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="stage-panel stage-panel--alt reveal-on-scroll">
      <div class="stage-content">
        <span class="stage-number">03</span>
        <h3>{stages[2].heading}</h3>
        <p>{stages[2].body}</p>
        <ol class="stage-steps">
          {stages[2].steps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </div>
      <div class="stage-visual">
        <div class="video-wrapper">
          <video
            autoplay muted loop playsinline
            poster="/videos/how-it-works-poster.jpg"
            preload="none"
            class="how-video"
          >
            <source src="/videos/how-it-works.webm" type="video/webm" />
            <source src="/videos/how-it-works.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>

    <div class="stage-panel reveal-on-scroll">
      <div class="stage-content">
        <span class="stage-number">04</span>
        <h3>{stages[3].heading}</h3>
        <p>{stages[3].body}</p>
      </div>
      <div class="stage-visual stage-visual--full">
        <div class="diagram-cascade">
          <div class="cascade-node">
            <span class="cascade-number">1</span>
            <strong class="cascade-title">Elimination</strong>
            <span class="cascade-desc">Labelled tumour cells destroyed</span>
          </div>
          <div class="cascade-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </div>
          <div class="cascade-node">
            <span class="cascade-number">2</span>
            <strong class="cascade-title">Antigen Spreading</strong>
            <span class="cascade-desc">More tumour antigens released</span>
          </div>
          <div class="cascade-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </div>
          <div class="cascade-node">
            <span class="cascade-number">3</span>
            <strong class="cascade-title">Broader T Cells</strong>
            <span class="cascade-desc">Immune system learns more targets</span>
          </div>
          <div class="cascade-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </div>
          <div class="cascade-node">
            <span class="cascade-number">4</span>
            <strong class="cascade-title">Systemic Elimination</strong>
            <span class="cascade-desc">Tumours attacked beyond treatment site</span>
          </div>
        </div>
      </div>
      <div class="stage-visual stage-visual--full">
        <p class="stage-note">{stages[3].note}</p>
      </div>
    </div>

    <p class="medical-disclaimer reveal-on-scroll">{HOW_IT_WORKS.disclaimer}</p>
  </div>
</section>

<style>
  .section-header {
    max-width: var(--content-width);
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-intro {
    color: var(--color-body-secondary);
    font-size: var(--text-lg);
  }

  .stage-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--color-gray-50);
  }

  .stage-panel:last-of-type {
    border-bottom: none;
  }

  .stage-panel--alt {
    padding: var(--space-16) var(--space-8);
    margin: 0 calc(-1 * var(--space-8));
    border-radius: var(--radius-xl);
    background-color: var(--color-off-white);
    border-bottom: none;
  }

  .stage-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .stage-content h3 {
    margin-bottom: var(--space-4);
  }

  .stage-content p {
    color: var(--color-body-secondary);
    margin-bottom: var(--space-4);
  }

  .stage-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stage-list li {
    position: relative;
    padding-left: var(--space-6);
    color: var(--color-body-secondary);
    font-size: var(--text-sm);
  }

  .stage-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: var(--space-2);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .stage-steps {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    counter-reset: step-counter;
  }

  .stage-steps li {
    position: relative;
    padding-left: var(--space-10);
    color: var(--color-body-secondary);
    font-size: var(--text-sm);
    counter-increment: step-counter;
  }

  .stage-steps li::before {
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: var(--color-primary-light);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stage-note {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    margin-top: var(--space-4);
  }

  .stage-visual--full {
    grid-column: 1 / -1;
  }

  /* === Stage 1 Diagram: Problem === */
  .diagram-problem {
    width: 100%;
  }

  .diagram-split {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-8);
    align-items: stretch;
  }

  .diagram-vs {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diagram-side {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-4);
    border-radius: var(--radius-lg);
  }

  .diagram-side--blocked {
    background-color: rgba(13, 21, 32, 0.05);
  }

  .diagram-side--target {
    background-color: rgba(49, 127, 179, 0.08);
    border: 1px solid rgba(49, 127, 179, 0.2);
  }

  .diagram-side-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400);
  }

  .tumour {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tumour-inner {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    transition: background var(--transition-base);
  }

  .tumour--cold .tumour-inner {
    background: radial-gradient(circle at 40% 40%, #8ba4b8, #4a6a82);
  }

  .tumour--hot .tumour-inner {
    background: radial-gradient(circle at 40% 40%, #f0a06a, #c85a3a);
  }

  .target-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 64px;
    height: 64px;
    border: 2px dashed var(--color-primary-light);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: pulse-ring 3s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(49, 127, 179, 0.15);
  }

  .target-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 6px rgba(49, 127, 179, 0.5);
  }

  .tumour--cold .tumour-inner::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 2px;
    background-color: rgba(200, 70, 70, 0.5);
    transform: translate(-50%, -50%) rotate(45deg);
    border-radius: 1px;
    animation: cold-cross 3s ease-in-out infinite;
  }

  .tumour--cold .tumour-inner::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 2px;
    background-color: rgba(200, 70, 70, 0.5);
    transform: translate(-50%, -50%) rotate(-45deg);
    border-radius: 1px;
    animation: cold-cross 3s ease-in-out infinite;
  }

  @keyframes cold-cross {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }

  @keyframes pulse-ring {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; box-shadow: 0 0 8px rgba(49, 127, 179, 0.15); }
    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; box-shadow: 0 0 16px rgba(49, 127, 179, 0.35); }
  }

  .diagram-status {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-600);
  }

  .diagram-status--active {
    color: var(--color-primary);
  }

  .barrier-labels {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
    margin-top: var(--space-3);
  }

  .barrier-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .barrier-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-gray-400);
    flex-shrink: 0;
  }

  .barrier-text {
    font-size: var(--text-xs);
    color: var(--color-gray-600);
    line-height: var(--leading-snug);
  }

  /* === Stage 2 Diagram: Solution === */
  .diagram-solution {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
    padding: var(--space-4) 0;
  }

  .diagram-solution::before {
    content: '';
    position: absolute;
    top: 100px;
    left: 50%;
    width: 1px;
    height: calc(100% - 140px);
    background: linear-gradient(to bottom, var(--color-gray-100), rgba(189, 193, 198, 0.2));
    transform: translateX(-50%);
    pointer-events: none;
  }

  .solution-center {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    z-index: 2;
    animation: breathe-center 2.5s ease-in-out infinite;
  }

  .solution-center::after {
    content: '';
    position: absolute;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 1px solid rgba(49, 127, 179, 0.15);
    animation: ripple-glow 2.5s ease-in-out infinite;
  }

  @keyframes breathe-center {
    0%, 100% { transform: scale(1); box-shadow: var(--shadow-md); }
    50% { transform: scale(1.04); box-shadow: 0 6px 24px rgba(49, 127, 179, 0.25); }
  }

  @keyframes ripple-glow {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.08); opacity: 0.8; }
  }

  .solution-center-text {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-white);
    text-align: center;
    line-height: var(--leading-snug);
  }

  .solution-card {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    padding: 22px var(--space-6);
    border: 1px solid var(--color-gray-50);
    border-radius: var(--radius-lg);
    background-color: var(--color-white);
    box-shadow: var(--shadow-sm);
    width: 100%;
    max-width: 200px;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .solution-card:hover {
    z-index: 2;
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
  }

  .solution-card:hover .solution-icon {
    color: var(--color-primary-dark);
  }

  .solution-card strong {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-heading);
  }

  .solution-card span {
    font-size: var(--text-xs);
    color: var(--color-body-secondary);
  }

  .solution-icon {
    width: 32px;
    height: 32px;
    color: var(--color-primary);
    transition: color var(--transition-base);
  }

  /* === Stage 3 Video === */
  .video-wrapper {
    position: relative;
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background-color: var(--color-dark-bg);
    transition: box-shadow var(--transition-base);
  }

  .video-wrapper:hover {
    box-shadow: 0 0 0 2px var(--color-primary-light), var(--shadow-lg);
  }

  .how-video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  /* === Stage 4 Diagram: Cascade === */
  .diagram-cascade {
    display: grid;
    grid-template-columns: 1fr 30px 1fr 30px 1fr 30px 1fr;
    align-items: start;
    gap: 0;
    margin: var(--space-8) 0;
  }

  .cascade-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-6) var(--space-3);
    border: 1px solid var(--color-gray-50);
    border-radius: var(--radius-lg);
    background-color: var(--color-off-white);
    grid-column: span 1;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base), background-color var(--transition-base);
  }

  .cascade-node:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
    background-color: var(--color-white);
  }

  .cascade-node:hover .cascade-number {
    background-color: var(--color-primary-dark);
  }

  .cascade-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    flex-shrink: 0;
    transition: background-color var(--transition-base);
  }

  .cascade-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-heading);
  }

  .cascade-desc {
    font-size: var(--text-xs);
    color: var(--color-body-secondary);
  }

  .cascade-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: var(--space-10);
    grid-column: span 1;
  }

  .cascade-arrow svg {
    width: 16px;
    height: 16px;
    color: var(--color-primary-light);
  }

  .cascade-note {
    text-align: center;
  }

  /* === Disclaimer === */
  .medical-disclaimer {
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    text-align: center;
    margin-top: var(--space-16);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-gray-50);
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .stage-panel {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .stage-panel--alt {
      margin: 0;
      padding: var(--space-8) var(--space-8);
    }

    .diagram-split {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .diagram-vs {
      text-align: center;
    }

    .diagram-cascade {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .cascade-arrow {
      padding-top: 0;
      justify-content: center;
    }

    .cascade-arrow svg {
      width: 14px;
      height: 14px;
    }

    .cascade-node {
      grid-column: 1;
    }
  }

  @media (max-width: 480px) {
    .stage-panel {
      padding-top: var(--space-10);
      padding-bottom: var(--space-10);
    }

    .diagram-side {
      padding: var(--space-4) var(--space-4);
    }

    .tumour {
      width: 60px;
      height: 60px;
    }

    .tumour-inner {
      width: 48px;
      height: 48px;
    }

    .tumour--cold .tumour-inner::after,
    .tumour--cold .tumour-inner::before {
      width: 18px;
    }

    .target-ring {
      width: 48px;
      height: 48px;
    }
  }
</style>
