---
import { TIMELINE } from '../../data/siteConfig';
const milestones = TIMELINE.milestones;
---

<section id="timeline" class="section section-alt timeline-section">
  <div class="container">
    <div class="timeline-header reveal-on-scroll">
      <h2>{TIMELINE.heading}</h2>
      <p class="timeline-intro">{TIMELINE.intro}</p>
    </div>

    <div class="timeline-track">
      <div class="timeline-line" aria-hidden="true"></div>

      {
        milestones.map((m, i) => (
          <div
            class="milestone-wrapper reveal-on-scroll"
            style={`--i: ${i}`}
          >
            <div class="milestone-card">
              <span class="milestone-date">{m.date}</span>
              <p class="milestone-text">{m.text}</p>
            </div>
            <div class="milestone-dot" aria-hidden="true" data-index={i}></div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  (function () {
    const dots = document.querySelectorAll<HTMLElement>('.milestone-dot');
    if (!dots.length) return;

    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    if (reducedMotion) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-active');
          } else {
            entry.target.classList.remove('is-active');
          }
        }
      },
      { rootMargin: '-20% 0px -20% 0px', threshold: 0 }
    );

    dots.forEach((dot) => observer.observe(dot));
  })();
</script>

<style>
  .timeline-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .timeline-header h2 {
    margin-bottom: var(--space-3);
  }

  .timeline-intro {
    color: var(--color-body-secondary);
    font-size: var(--text-lg);
    max-width: 560px;
    margin: 0 auto;
  }

  .timeline-track {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-gray-200);
    transform: translateX(-50%);
    z-index: 0;
  }

  .milestone-wrapper {
    display: flex;
    position: relative;
    padding-bottom: var(--space-10);
  }

  .milestone-wrapper:last-child {
    padding-bottom: 0;
  }

  .milestone-wrapper:nth-child(odd) {
    justify-content: flex-start;
  }

  .milestone-wrapper:nth-child(even) {
    justify-content: flex-end;
  }

  .milestone-card {
    position: relative;
    width: calc(50% - 44px);
    max-width: 360px;
    background: var(--color-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    padding: var(--space-6);
  }

  .milestone-wrapper:nth-child(odd) .milestone-card {
    text-align: right;
  }

  .milestone-card::after {
    content: '';
    position: absolute;
    top: calc(var(--space-6) + 7px);
    width: 24px;
    height: 2px;
    background: var(--color-gray-200);
  }

  .milestone-wrapper:nth-child(odd) .milestone-card::after {
    right: -24px;
  }

  .milestone-wrapper:nth-child(even) .milestone-card::after {
    left: -24px;
  }

  .milestone-date {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }

  .milestone-text {
    font-size: var(--text-sm);
    color: var(--color-body);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .milestone-dot {
    position: absolute;
    left: 50%;
    top: var(--space-6);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-primary);
    z-index: 2;
    transform: translateX(-50%);
    box-shadow: 0 0 0 3px var(--color-off-white),
      0 0 0 0 rgba(49, 127, 179, 0.2);
    transition: box-shadow var(--transition-base);
    will-change: box-shadow;
  }

  .milestone-dot.is-active {
    box-shadow: 0 0 0 3px var(--color-off-white),
      0 0 0 7px rgba(49, 127, 179, 0.2);
  }

  .milestone-wrapper {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: calc(var(--i, 0) * 0.08s);
  }

  .milestone-wrapper.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .timeline-header {
      margin-bottom: var(--space-10);
    }

    .timeline-track {
      padding-left: 36px;
    }

    .timeline-line {
      left: 16px;
      transform: none;
    }

    .milestone-wrapper {
      padding-bottom: var(--space-6);
    }

    .milestone-wrapper:nth-child(odd),
    .milestone-wrapper:nth-child(even) {
      justify-content: flex-start;
    }

    .milestone-card {
      width: 100%;
      max-width: none;
      text-align: left;
    }

    .milestone-wrapper:nth-child(odd) .milestone-card {
      text-align: left;
    }

    .milestone-card::after {
      display: none;
    }

    .milestone-dot {
      left: 0;
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .milestone-wrapper {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .milestone-dot {
      transition: none;
    }

    .milestone-dot.is-active {
      box-shadow: 0 0 0 3px var(--color-off-white);
    }
  }
</style>
