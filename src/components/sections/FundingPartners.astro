---
import { FUNDING_CTA } from '../../data/siteConfig';
---

<section id="funding" class="section section-alt">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2>{FUNDING_CTA.heading}</h2>
      <p class="section-intro">{FUNDING_CTA.intro}</p>
    </div>
    <div class="funding-cards">
      {FUNDING_CTA.audienceCards.map((card) => (
        <article class="funding-card reveal-on-scroll">
          <div class="funding-card-icon">
            {card.icon === 'investor' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v4M12 22v-4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M22 12h-4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                <circle cx="12" cy="12" r="4"/>
              </svg>
            ) : card.icon === 'pharma' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                <rect x="8" y="2" width="8" height="4" rx="1"/>
                <path d="M12 11v6M9 14h6"/>
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            )}
          </div>
          <h3>{card.heading}</h3>
          <p>{card.body}</p>
          <a href={card.href} class="btn btn-primary">{card.cta}</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    max-width: var(--content-width);
    margin: 0 auto var(--space-12);
    text-align: center;
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-intro {
    color: var(--color-body-secondary);
    font-size: var(--text-lg);
  }

  .funding-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .funding-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-6);
    border: 1px solid var(--color-gray-50);
    border-radius: var(--radius-lg);
    background-color: var(--color-white);
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .funding-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .funding-card-icon {
    width: 40px;
    height: 40px;
    color: var(--color-primary);
  }

  .funding-card h3 {
    font-size: var(--text-lg);
  }

  .funding-card p {
    font-size: var(--text-sm);
    color: var(--color-body-secondary);
    flex: 1;
  }

  .funding-card .btn-primary {
    align-self: flex-start;
  }

  @media (max-width: 900px) {
    .funding-cards {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
