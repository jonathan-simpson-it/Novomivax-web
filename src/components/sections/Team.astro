---
import { CORE_TEAM } from '../../data/siteConfig';
---

<section id="team" class="section">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2>{CORE_TEAM.heading}</h2>
      <p class="section-intro">{CORE_TEAM.intro}</p>
    </div>
    <div class="team-grid">
      {CORE_TEAM.members.map((member) => (
        <article class="team-card reveal-on-scroll">
          <span class="team-role">{member.role}</span>
          <span class="team-subtitle">{member.subtitle}</span>
          <div class="portrait-placeholder" aria-hidden="true">
            <svg
              viewBox="0 0 60 60"
              fill="none"
              width="28"
              height="28"
              class="portrait-icon"
            >
              <circle cx="30" cy="22" r="10" fill="currentColor" />
              <path
                d="M8 54c0-12 10-22 22-22s22 10 22 22"
                fill="currentColor"
              />
            </svg>
          </div>
          <span class="team-name">{member.name}</span>
          <ul class="team-bio">
            {member.bio.map((line) => (
              <li class="team-bio-line">{line}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    max-width: var(--content-width);
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-intro {
    color: var(--color-body-secondary);
    font-size: var(--text-lg);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-1);
    align-items: stretch;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    border: 1px solid var(--color-gray-50);
    border-radius: var(--radius-lg);
    background-color: var(--color-white);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .team-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .team-role {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .team-subtitle {
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    margin-bottom: var(--space-2);
  }

  .portrait-placeholder {
    aspect-ratio: 16 / 10;
    background-color: var(--color-gray-50);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-2);
    color: var(--color-gray-200);
  }

  .portrait-icon {
    display: block;
  }

  .team-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-heading);
    margin-bottom: var(--space-2);
  }

  .team-bio {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .team-bio-line {
    position: relative;
    padding-left: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-body-secondary);
    line-height: 1.2;
  }

  .team-bio-line::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-gray-200);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
